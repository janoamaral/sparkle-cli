# Copy this file to .env before running docker compose.
# docker compose automatically loads .env from this directory.

# Public URL used by SearXNG itself
SEARXNG_BASE_URL=http://localhost:8080/

# Optional: set this if your Qdrant instance requires authentication.
# You can reference it from sparkle-cli config as ${QDRANT_API_KEY}.
QDRANT_API_KEY=
